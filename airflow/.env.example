# Airflow runtime
AIRFLOW_UID=50000
OPEN_DART_API_KEY=replace_with_real_open_dart_api_key
_PIP_ADDITIONAL_REQUIREMENTS=pykrx boto3 pyarrow psycopg2-binary

# Airflow metadata Postgres
POSTGRES_USER=airflow
POSTGRES_PASSWORD=replace_with_real_airflow_postgres_password
POSTGRES_DB=airflow
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:replace_with_real_airflow_postgres_password@postgres/airflow

# Airflow admin user
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=replace_with_real_airflow_admin_password
AIRFLOW_ADMIN_FIRSTNAME=Airflow
AIRFLOW_ADMIN_LASTNAME=Admin
AIRFLOW_ADMIN_EMAIL=admin@example.com

# Seeded Airflow Variables
STOCK_SIGNAL_STOCK_CODE=005930
STOCK_SIGNAL_AWS_ACCESS_KEY_ID=
STOCK_SIGNAL_AWS_SECRET_ACCESS_KEY=
STOCK_SIGNAL_AWS_SESSION_TOKEN=
STOCK_SIGNAL_S3_BUCKET=replace_with_real_s3_bucket_name
STOCK_SIGNAL_S3_REGION=ap-northeast-2
STOCK_SIGNAL_S3_BRONZE_PREFIX=bronze
STOCK_SIGNAL_S3_SILVER_PREFIX=silver
STOCK_SIGNAL_WEB_POSTGRES_HOST=host.docker.internal
STOCK_SIGNAL_WEB_POSTGRES_PORT=5433
STOCK_SIGNAL_WEB_POSTGRES_DB=stock_signal
STOCK_SIGNAL_WEB_POSTGRES_USER=stock_signal
STOCK_SIGNAL_WEB_POSTGRES_PASSWORD=replace_with_real_web_postgres_password
